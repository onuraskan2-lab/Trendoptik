/* --- PREMIUM SOLID ARCHITECTURE STYLES --- */
:root {
    --bg-color: #050505; --card-bg: #0a0a0a; --text-color: #ffffff; --gold-color: #d4af37; --border-color: rgba(212, 175, 55, 0.15);
}
body[data-theme="luxury"] {
    --bg-color: #050505; --card-bg: #0a0a0a; --text-color: #ffffff; --gold-color: #d4af37; --border-color: rgba(212, 175, 55, 0.15);
}
body[data-theme="midnight"] {
    --bg-color: #0a1128; --card-bg: #101f42; --text-color: #f8fafc; --gold-color: #38bdf8; --border-color: rgba(56, 189, 248, 0.15);
}
body[data-theme="rose"] {
    --bg-color: #1a0f1a; --card-bg: #2d162d; --text-color: #fff5f5; --gold-color: #b76e79; --border-color: rgba(183, 110, 121, 0.2);
}
body[data-theme="cyber"] {
    --bg-color: #0f0f11; --card-bg: #17171c; --text-color: #ffffff; --gold-color: #00ff66; --border-color: rgba(0, 255, 102, 0.2);
}

* { margin: 0; padding: 0; box-sizing: border-box; }
body { background-color: var(--bg-color); color: var(--text-color); font-family: 'Montserrat', sans-serif; line-height: 1.6; overflow-x: hidden; transition: background 0.3s, color 0.3s; }

.announcement-bar { background-color: var(--gold-color); color: #000; text-align: center; padding: 6px 10px; font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; z-index: 101; position: relative; }

header { background-color: var(--bg-color); padding: 15px 20px; border-bottom: 1px solid var(--border-color); position: sticky; top: 0; z-index: 100; }
.header-container { display: flex; justify-content: space-between; align-items: center; max-width: 1400px; margin: 0 auto; width: 100%; }
header h1.logo { font-family: 'Cinzel', serif; font-size: 18px; font-weight: 600; letter-spacing: 3px; }
header h1 .city { color: var(--gold-color); font-size: 12px; }

.header-left-controls { display: flex; align-items: center; gap: 6px; }
.ctrl-icon-btn { background: #111; border: 1px solid #222; color: #fff; width: 30px; height: 30px; border-radius: 4px; font-size: 11px; cursor: pointer; font-weight: bold; }

.theme-palette-wrapper { display: flex; gap: 5px; margin-left: 5px; background: #000; padding: 4px 8px; border-radius: 20px; border: 1px solid #1a1a1a; }
.theme-dot { width: 12px; height: 12px; border-radius: 50%; cursor: pointer; display: block; border: 1px solid rgba(255,255,255,0.2); }
.theme-dot.luxury { background: #d4af37; }
.theme-dot.midnight { background: #38bdf8; }
.theme-dot.rose { background: #b76e79; }
.theme-dot.cyber { background: #00ff66; }

/* Burger */
.burger-menu { display: flex; flex-direction: column; justify-content: space-between; width: 24px; height: 14px; cursor: pointer; z-index: 110; position: relative; }
.burger-menu .bar { height: 2px; width: 100%; background-color: var(--gold-color); transition: all 0.3s ease; }
.burger-menu.active .bar:nth-child(1) { transform: translateY(6px) rotate(45deg); background-color: #fff; }
.burger-menu.active .bar:nth-child(2) { opacity: 0; }
.burger-menu.active .bar:nth-child(3) { transform: translateY(-6px) rotate(-45deg); background-color: #fff; }

/* KATI SİYAH MENÜ */
.nav-menu { position: fixed; top: 0; left: -100%; width: 100%; height: 100vh; background-color: #0c0c0e; transition: left 0.4s ease; z-index: 104; display: flex; align-items: center; justify-content: center; }
.nav-menu.active { left: 0; }
.nav-menu-inner { max-width: 500px; width: 100%; text-align: center; padding: 20px; max-height: 90vh; overflow-y: auto; }
.nav-menu ul { list-style: none; display: flex; flex-direction: column; align-items: center; width: 100%; }
.nav-menu ul li { width: 100%; margin: 8px 0; }
.nav-menu ul li a { text-decoration: none; color: #ffffff; font-size: 14px; letter-spacing: 2px; }
.nav-menu ul li a:hover { color: var(--gold-color); }

.main-nav-item { font-family: 'Cinzel', serif !important; font-size: 16px !important; font-weight: 600; color: #fff !important; }
.featured-nav-link { color: var(--gold-color) !important; }
.menu-divider { color: #444 !important; font-size: 9px !important; letter-spacing: 3px !important; font-weight: 700; margin: 20px 0 5px !important; pointer-events: none; border-bottom: 1px solid #1a1a1a; padding-bottom: 4px; width: 100%; }

.face-shape-row { display: flex; justify-content: center; gap: 6px; width: 100%; margin: 4px 0; }
.face-shape-row li { width: auto; margin: 0; }
.face-link { font-size: 10px !important; border: 1px solid #222; padding: 5px 12px; border-radius: 20px; background: #111; }

.menu-custom-logo-img { height: 30px; max-width: 140px; object-fit: contain; filter: brightness(0) invert(1); }
.menu-custom-text-logo { font-family: 'Cinzel', serif !important; font-size: 16px !important; letter-spacing: 4px !important; color: var(--gold-color) !important; }

/* Stories */
.stories-wrapper { display: flex; gap: 14px; overflow-x: auto; padding: 15px; background: var(--bg-color); border-bottom: 1px solid var(--border-color); scrollbar-width: none; }
.stories-wrapper::-webkit-scrollbar { display: none; }
.story-node { display: flex; flex-direction: column; align-items: center; text-align: center; cursor: pointer; flex-shrink: 0; }
.story-ring { width: 64px; height: 64px; border-radius: 50%; border: 2px solid var(--gold-color); padding: 2px; background: #000; overflow: hidden; }
.story-ring img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
.story-node span { font-size: 10px; color: #aaa; margin-top: 6px; }

/* Video */
.video-hero { position: relative; width: 100%; height: 32vh; overflow: hidden; display: flex; justify-content: center; align-items: center; }
.hero-video { position: absolute; top: 50%; left: 50%; width: 100%; height: 100%; object-fit: cover; transform: translate(-50%, -50%); z-index: 1; }
.video-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(rgba(0,0,0,0.3), var(--bg-color)); z-index: 2; }
.hero-content { position: relative; z-index: 3; text-align: center; }
.hero-content h2 { font-family: 'Cinzel', serif; font-size: 24px; letter-spacing: 4px; color: var(--gold-color); }
.hero-content p { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; margin-top: 5px; color: #fff; }

/* Süzgeçler */
.search-sort-wrapper { max-width: 600px; margin: -20px auto 35px; display: flex; gap: 8px; padding: 0 10px; position: relative; z-index: 10; }
#showroomSearch { flex-grow: 1; padding: 14px 20px; background: #0c0c0c; border: 1px solid var(--border-color); border-radius: 25px; color: #fff; font-family: 'Montserrat', sans-serif; font-size: 13px; outline: none; }
#showroomSort { background: #0c0c0c; border: 1px solid var(--border-color); border-radius: 25px; color: var(--gold-color); font-family: 'Montserrat', sans-serif; font-size: 12px; padding: 0 15px; outline: none; }

.container { padding: 40px 10px; max-width: 1400px; margin: 0 auto; }
.section-title { font-family: 'Cinzel', serif; text-align: center; font-size: 18px; letter-spacing: 4px; }
.section-subtitle { text-align: center; font-size: 10px; letter-spacing: 1px; color: var(--gold-color); text-transform: uppercase; margin-bottom: 35px; }

/* Katalog Grid */
.luxury-catalog-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }

.card { background: var(--card-bg); border: 1px solid var(--border-color); position: relative; display: flex; flex-direction: column; overflow: hidden; cursor: pointer; }
.card.hidden { display: none !important; }
.card.scanned-highlight { border-color: var(--gold-color) !important; box-shadow: 0 0 15px var(--gold-color); }

.featured-badge { position: absolute; top: 6px; left: 6px; background: var(--gold-color); color: #000; font-size: 8px; font-weight: 700; padding: 2px 5px; z-index: 5; }
.custom-badge { position: absolute; top: 6px; right: 6px; background: #ff4444; color: #fff; font-size: 8px; font-weight: 700; padding: 2px 5px; z-index: 5; }
.card-fav-trigger { position: absolute; bottom: 6px; left: 6px; background: rgba(0,0,0,0.7); border: 1px solid #333; color: #fff; font-size: 12px; width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center; z-index: 6; cursor: pointer; }
.card-fav-trigger.liked { background: #fff; color: #ff4444; border-color: #fff; }

.img-container { width: 100%; height: 165px; overflow: hidden; background: #111; position: relative; }
.card img.main-display-img { width: 100%; height: 100%; object-fit: cover; }

.card-info { padding: 10px 5px; text-align: center; flex-grow: 1; }
.card-brand { font-family: 'Cinzel', serif; font-size: 12px; color: var(--gold-color); letter-spacing: 1px; }
.card-title { font-size: 11px; color: #999; font-weight: 300; margin: 1px 0 5px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.card-price-box { display: flex; justify-content: center; align-items: center; gap: 6px; font-size: 11px; }
.old-price { color: #444; text-decoration: line-through; font-size: 9px; }
.current-price { font-weight: 700; color: #fff; }
.current-price.discounted { color: var(--gold-color); }
.whatsapp-btn { display: block; background-color: #128c7e; color: #ffffff; text-decoration: none; padding: 8px; font-size: 10px; font-weight: 700; text-align: center; text-transform: uppercase; }

/* Modals */
.lux-detail-modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.95); z-index: 200; overflow-y: auto; padding: 15px 5px; }
.lux-detail-content { background: #090909; border: 1px solid var(--border-color); max-width: 450px; margin: 15px auto; padding: 25px 15px; border-radius: 6px; position: relative; }
.lux-detail-close { position: absolute; top: 8px; right: 15px; color: #fff; font-size: 30px; cursor: pointer; z-index: 10; }
.modal-img-frame { width: 100%; height: 250px; background: #111; overflow: hidden; border-radius: 4px; margin-bottom: 12px; }
.modal-img-frame img { width: 100%; height: 100%; object-fit: cover; }

.modal-gallery-strip { display: flex; gap: 6px; overflow-x: auto; padding-bottom: 12px; margin-bottom: 12px; border-bottom: 1px solid #161616; justify-content: center; }
.modal-thumb-node { width: 42px; height: 42px; object-fit: cover; border: 1px solid #222; cursor: pointer; opacity: 0.4; }
.modal-thumb-node.active { border-color: var(--gold-color); opacity: 1; }

.modal-info-box { text-align: center; margin-bottom: 15px; }
.modal-brand { font-family: 'Cinzel', serif; font-size: 18px; color: var(--gold-color); letter-spacing: 2px; }
.modal-title { font-size: 13px; color: #bbb; margin: 4px 0 12px; font-weight: 300; }
.modal-meta-row { display: flex; justify-content: center; gap: 6px; margin-bottom: 12px; flex-wrap: wrap; }
.modal-meta-tag { background: #000; border: 1px solid #1c1c1c; font-size: 10px; padding: 3px 8px; color: #999; text-transform: uppercase; }
.modal-share-btn { background: transparent; border: 1px solid #333; color: #888; font-size: 10px; padding: 4px 10px; cursor: pointer; margin-top: 10px; }
.modal-share-btn:hover { border-color: var(--gold-color); color: var(--gold-color); }

.floating-fav-basket { position: fixed; bottom: 20px; right: 15px; background: var(--gold-color); color: #000; padding: 12px 20px; border-radius: 30px; font-weight: 700; font-size: 12px; display: flex; align-items: center; gap: 6px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); z-index: 90; cursor: pointer; }

/* 2D Sanal Ayna */
.lux-mirror-box { background: #050505; border: 1px solid #1f1f1f; border-radius: 4px; padding: 15px; margin: 15px 0; text-align: center; }
.lux-mirror-title { font-family: 'Cinzel', serif; font-size: 11px; color: var(--gold-color); letter-spacing: 1px; margin-bottom: 10px; }
.mirror-work-bench { width: 100%; height: 260px; background: #000; border: 1px dashed #333; border-radius: 4px; position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center; }
.mirror-user-selfie { width: 100%; height: 100%; object-fit: cover; position: absolute; top: 0; left: 0; z-index: 1; }
.mirror-overlay-glasses { width: 120px; height: auto; position: absolute; z-index: 2; transform: translate(-50%, -50%); filter: drop-shadow(0 4px 8px rgba(0,0,0,0.5)); mix-blend-mode: normal; pointer-events: none; }
.bench-empty-msg { font-size: 11px; color: #444; z-index: 3; max-width: 220px; line-height: 1.6; }

.mirror-controls-pad { margin-top: 12px; background: #0c0c0c; padding: 10px; border-radius: 4px; border: 1px solid #111; }
.slider-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px; gap: 8px; }
.slider-row label { font-size: 9px; color: #666; font-weight: 600; width: 60px; text-align: left; }
.mirror-slider { flex-grow: 1; accent-color: var(--gold-color); height: 3px; background: #222; outline: none; }

/* Widgets */
.live-store-status { margin-bottom: 15px; font-size: 11px; font-weight: 700; display: inline-block; padding: 4px 15px; border-radius: 4px; }
.live-store-status.open { background: rgba(18, 140, 126, 0.15); color: #128c7e; border: 1px solid #128c7e; }
.live-store-status.closed { background: rgba(255, 68, 68, 0.15); color: #ff4444; border: 1px solid #ff4444; }

.trust-slider-section { background: #090909; padding: 40px 15px; text-align: center; border-top: 1px solid #111; }
.trust-section-title { font-family: 'Cinzel', serif; font-size: 14px; color: #444; letter-spacing: 3px; margin-bottom: 20px; }
.trust-slider-container { max-width: 600px; margin: 0 auto; }
.trust-text { font-size: 13px; color: #aaa; font-style: italic; }
.trust-author { font-size: 11px; color: var(--gold-color); margin-top: 8px; font-weight: 600; }

.faq-section { background: #050505; padding: 40px 15px; border-top: 1px solid #111; }
.faq-section-title { font-family: 'Cinzel', serif; font-size: 14px; color: #444; letter-spacing: 3px; text-align: center; margin-bottom: 25px; }
.faq-container { max-width: 600px; margin: 0 auto; }
.faq-item { border-bottom: 1px solid #161616; margin-bottom: 10px; }
.faq-trigger { font-size: 12px; font-weight: 600; color: #fff; padding: 12px 5px; cursor: pointer; position: relative; }
.faq-trigger::after { content: '+'; position: absolute; right: 5px; color: var(--gold-color); }
.faq-item.active .faq-trigger::after { content: '-'; }
.faq-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; background: #090909; }
.faq-content p { font-size: 12px; color: #777; padding: 15px; }
.faq-item.active .faq-content { max-height: 200px; }

.store-info-section { background-color: #080808; padding: 35px 10px; border-top: 1px solid var(--border-color); text-align: center; }
.store-info-container { max-width: 800px; margin: 0 auto; }
.store-title { font-family: 'Cinzel', serif; font-size: 16px; letter-spacing: 3px; color: var(--gold-color); margin-bottom: 10px; }
.store-details-grid { display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px; text-align: left; margin-top: 15px; }
.store-detail-card { background: #040404; border: 1px solid #111; padding: 12px; }
.store-detail-card h5 { font-family: 'Cinzel', serif; font-size: 11px; color: #ffffff; margin-bottom: 4px; border-left: 2px solid var(--gold-color); padding-left: 6px; }
.store-detail-card p { font-size: 11px; color: #666; }
.store-action-btn-row { display: flex; flex-direction: column; gap: 8px; max-width: 320px; margin: 0 auto; }
.maps-btn { display: block; background: transparent; color: #ffffff; border: 1px solid #ffffff; padding: 10px; font-size: 11px; text-decoration: none; font-weight: 600; text-align: center; }

.instagram-feed-section { background: #000; padding: 40px 10px; border-top: 1px solid #111; text-align: center; }
.ig-section-title { font-family: 'Cinzel', serif; font-size: 12px; color: #333; letter-spacing: 2px; margin-bottom: 20px; }
.instagram-mock-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; max-width: 600px; margin: 0 auto; }
.ig-post { width: 100%; aspect-ratio: 1; overflow: hidden; background: #111; }
.ig-post img { width: 100%; height: 100%; object-fit: cover; }

footer { background-color: #010101; text-align: center; padding: 30px 10px; border-top: 1px solid #111; }
.footer-brand { font-family: 'Cinzel', serif; font-size: 15px; letter-spacing: 2px; margin-bottom: 10px; }
.social-btn { background-color: transparent; color: var(--gold-color); border: 1px solid var(--gold-color); padding: 8px 20px; font-size: 11px; cursor: pointer; }
.copyright { font-size: 10px; color: #333; display: block; margin-top: 12px; }

/* Admin Base Blocks */
.admin-body-bg { background: #030303; min-height: 100vh; display: flex; justify-content: center; align-items: center; padding: 12px; width: 100%; }
.admin-auth-screen { background: #080808; border: 1px solid rgba(212, 175, 55, 0.15); padding: 35px 20px; border-radius: 6px; text-align: center; max-width: 350px; width: 100%; }
.admin-auth-screen h2 { font-family: 'Cinzel', serif; color: #fff; letter-spacing: 3px; font-size: 18px; margin-bottom: 4px; }
.admin-auth-screen h3 { font-size: 9px; color: #d4af37; letter-spacing: 2px; margin-bottom: 20px; }
.auth-form-group input { width: 100%; padding: 11px; background: #000; border: 1px solid #1f1f1f; border-radius: 4px; color: #fff; text-align: center; margin-bottom: 10px; outline: none; }
.auth-form-group button { width: 100%; background: #d4af37; color: #000; font-weight: 700; font-size: 11px; padding: 11px; border: none; cursor: pointer; }

.secure-main-dashboard { width: 100%; max-width: 500px; }
.admin-section-block { background: #080808; border: 1px solid #161616; padding: 20px 15px; border-radius: 6px; margin-bottom: 20px; }
.block-header { font-family: 'Cinzel', serif; font-size: 11px; color: #d4af37; font-weight: 600; letter-spacing: 1px; margin-bottom: 18px; display: flex; align-items: center; gap: 8px; border-bottom: 1px solid #161616; padding-bottom: 8px; }
.block-header span { background: #d4af37; color: #000; font-size: 10px; font-weight: 700; padding: 1px 5px; border-radius: 2px; }

.admin-form .form-row { display: flex; gap: 10px; }
.admin-form .form-group { margin-bottom: 12px; width: 100%; }
.admin-form .form-group.half { width: 50%; }
.admin-form label { display: block; font-size: 9px; color: #555; margin-bottom: 4px; font-weight: 600; }
.admin-form input, .admin-form select { width: 100%; padding: 10px; background: #000; border: 1px solid #1c1c1c; color: #fff; font-family: 'Montserrat', sans-serif; font-size: 12px; border-radius: 4px; outline: none; }

.file-input { border: 1px dashed #d4af37 !important; padding: 10px !important; background: #0c0b05 !important; color: #444; }
.preview-title { font-size: 9px; color: #d4af37; margin: 10px 0 4px; }
.admin-preview-grid { display: flex; gap: 5px; overflow-x: auto; padding: 2px 0; }
.admin-preview-item { position: relative; width: 55px; height: 55px; border: 1px solid #222; overflow: hidden; flex-shrink: 0; cursor: pointer; }
.admin-preview-item img { width: 100%; height: 100%; object-fit: cover; }
.admin-preview-item.is-cover { border-color: #d4af37; border-width: 2px; }
.checkbox-group { display: flex; align-items: center; gap: 6px; margin-top: 5px; }
.lux-checkbox { width: 14px; height: 14px; accent-color: #d4af37; }
.checkbox-label { color: #d4af37 !important; font-size: 10px; font-weight: 600; }

.admin-submit-btn { width: 100%; background: #d4af37; color: #000; border: none; padding: 11px; font-weight: 600; font-size: 11px; cursor: pointer; text-transform: uppercase; margin-top: 5px; }
.admin-submit-btn-gold { width: 100%; background: transparent; color: #d4af37; border: 1px solid #d4af37; padding: 11px; font-weight: 600; font-size: 11px; cursor: pointer; text-transform: uppercase; margin-top: 5px; }

.admin-control-list { max-height: 250px; overflow-y: auto; background: #000; border: 1px solid #161616; border-radius: 4px; padding: 5px; margin-bottom: 20px; }
.admin-ctrl-item { display: flex; flex-direction: column; padding: 10px; border-bottom: 1px solid #0e0e0e; gap: 10px; background: #050505; margin-bottom: 5px; }
.admin-ctrl-row-top { display: flex; align-items: center; justify-content: space-between; width: 100%; }
.admin-ctrl-info h6 { font-size: 11px; color: #fff; font-weight: 600; }
.admin-ctrl-info p { font-size: 9px; color: #d4af37; margin-top: 2px; }
.admin-ctrl-qr-box img { background: #fff; padding: 3px; width: 55px; height: 55px; object-fit: contain; }

.admin-ctrl-action-bar { display: flex; gap: 6px; width: 100%; border-top: 1px solid #111; padding-top: 8px; }
.admin-mini-inline-btn { flex: 1; padding: 5px; font-size: 9px; font-weight: 700; cursor: pointer; border: 1px solid #222; background: #000; color: #aaa; text-transform: uppercase; }
.admin-mini-inline-btn.print { color: #d4af37; border-color: #d4af37; }
.admin-mini-inline-btn.del { color: #ff4444; border-color: #ff4444; max-width: 40px; }

.admin-clear-btn { width: 100%; background: transparent; color: #ff4444; border: 1px solid #ff4444; padding: 6px; font-size: 10px; cursor: pointer; margin-top: 10px; }
.admin-logout-btn { width: 100%; background: #161616; color: #999; border: none; padding: 6px; font-size: 10px; cursor: pointer; margin-top: 5px; }
.admin-backup-zone { background: #000; border: 1px solid #161616; padding: 10px; }
.backup-btn-row { display: flex; gap: 6px; }
.backup-btn { flex: 1; text-align: center; padding: 8px; font-size: 9px; font-weight: 600; cursor: pointer; border-radius: 4px; border: none; font-family: 'Montserrat', sans-serif; }
.backup-btn.export { background: transparent; color: #d4af37; border: 1px solid #d4af37; }
.backup-btn.import { background: transparent; color: #fff; border: 1px solid #222; display: block; }

@media print {
    body * { display: none !important; }
    #qrPrintIsolatedFrame { display: block !important; width: 40mm !important; height: 40mm !important; background: #fff !important; padding: 2mm !important; position: absolute; top: 0; left: 0; }
    #qrPrintIsolatedFrame img { width: 100% !important; height: auto !important; display: block !important; mix-blend-mode: multiply; }
}

@media (min-width: 768px) {
    .burger-menu { display: none; }
    .nav-menu { position: static; height: auto; width: auto; background: none; overflow: visible; }
    .nav-menu-inner { max-width: none; width: auto; padding: 0; }
    .nav-menu ul { flex-direction: row; }
    .nav-menu ul li { margin: 0 0 0 25px; width: auto; }
    .menu-divider { display: none !important; }
    .face-shape-row { display: flex; gap: 25px; }
